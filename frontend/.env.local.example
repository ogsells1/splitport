# Privy — получи на https://dashboard.privy.io
NEXT_PUBLIC_PRIVY_APP_ID=your-privy-app-id-here
# App Secret из Privy Dashboard → Settings. ОБЯЗАТЕЛЕН: сервер проверяет им
# access-token каждого запроса к /api. Без него все user-scoped роуты вернут 503.
PRIVY_APP_SECRET=your-privy-app-secret-here

# Treasury (кастодиальный баланс)
# Публичный адрес кошелька-трежери, КУДА участники шлют USDC при крипто-пополнении.
NEXT_PUBLIC_TREASURY_ADDRESS=0x...
# Приватный ключ того же кошелька — нужен для будущей фазы (распределение из трежери).
EXECUTOR_PRIVATE_KEY=0x...

# Stripe (card top-up) — получи на https://dashboard.stripe.com (test mode)
STRIPE_SECRET_KEY=sk_test_...
# Секрет вебхука из Stripe Dashboard → Developers → Webhooks (endpoint /api/treasury/webhook)
STRIPE_WEBHOOK_SECRET=whsec_...
