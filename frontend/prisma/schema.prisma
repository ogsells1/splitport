generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  privyId   String   @unique
  email     String?
  wallet    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects         Project[]
  transactions     Transaction[]
  treasuryDeposits TreasuryDeposit[]

  @@map("users")
}

model Project {
  id              String   @id @default(cuid())
  name            String
  contractAddress String   @unique
  usdcAddress     String
  chainId         Int      @default(5042002)
  deployBlock     BigInt?
  ownerId         String
  // How payouts are computed: PERCENTAGE splits an input amount by basis points;
  // FIXED pays each contributor their own fixed amount. Set at creation, immutable.
  splitMode       SplitMode @default(PERCENTAGE)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  owner         User             @relation(fields: [ownerId], references: [id])
  contributors  Contributor[]
  transactions  Transaction[]
  distributions    Distribution[]
  payouts          Payout[]
  schedule         PayoutSchedule?
  scheduledPayouts ScheduledPayout[]
  streams          PayoutStream[]

  @@map("projects")
}

enum SplitMode {
  PERCENTAGE
  FIXED
}

// Owner-configured automatic payouts. A daily cron distributes a fixed amount
// from the treasury across the project's contributors whenever nextRunAt is due.
// One schedule per project. WEEKLY/MONTHLY auto-advance nextRunAt after each run;
// CUSTOM is a one-shot run that deactivates itself afterwards.
model PayoutSchedule {
  id        String            @id @default(cuid())
  projectId String            @unique
  frequency ScheduleFrequency
  amount    BigInt            // fixed USDC per run, 6 decimals
  nextRunAt DateTime
  active    Boolean           @default(true)
  lastRunAt DateTime?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  project Project @relation(fields: [projectId], references: [id])

  @@index([active, nextRunAt])
  @@map("payout_schedules")
}

// Owner-queued one-off payouts: any number per project, each a fixed amount to
// distribute once on a future date. The same daily cron runs due PENDING ones
// (distributes across contributors by %) and marks them DONE. Distinct from the
// single recurring PayoutSchedule above — this is an unbounded queue.
model ScheduledPayout {
  id             String                @id @default(cuid())
  projectId      String
  amount         BigInt                // fixed USDC, 6 decimals
  runAt          DateTime
  status         ScheduledPayoutStatus @default(PENDING)
  distributionId String?               // set once executed
  createdAt      DateTime              @default(now())
  ranAt          DateTime?

  project Project @relation(fields: [projectId], references: [id])

  @@index([status, runAt])
  @@map("scheduled_payouts")
}

enum ScheduledPayoutStatus {
  PENDING
  DONE
  CANCELED
}

enum ScheduleFrequency {
  WEEKLY
  MONTHLY
  CUSTOM
}

// Superfluid-style continuous payout. The owner commits `total` USDC over a time
// window [startAt, endAt]; each contributor's share accrues linearly and is
// claimable at any moment (accrued − alreadyClaimed). Accrual is computed on read
// (no cron). The full total is reserved from the treasury upfront (buffer); on
// cancel, accrual stops and the unclaimed remainder returns to the treasury.
model PayoutStream {
  id         String       @id @default(cuid())
  projectId  String
  total      BigInt       // total USDC over the window, 6 decimals
  startAt    DateTime
  endAt      DateTime
  status     StreamStatus @default(ACTIVE)
  canceledAt DateTime?
  createdAt  DateTime     @default(now())

  project Project       @relation(fields: [projectId], references: [id])
  shares  StreamShare[]

  @@index([status])
  @@map("payout_streams")
}

enum StreamStatus {
  ACTIVE
  CANCELED
}

// A contributor's slice of a PayoutStream. `amount` is their full share over the
// whole window (split by basis points at creation). `claimedAmount` tracks how
// much they've already pulled. wallet is null while the invite is unclaimed.
model StreamShare {
  id            String  @id @default(cuid())
  streamId      String
  contributorId String?
  wallet        String? // lowercased; null until the invite is linked
  amount        BigInt  // this contributor's total share over the full window
  claimedAmount BigInt  @default(0)

  stream      PayoutStream  @relation(fields: [streamId], references: [id])
  contributor Contributor?  @relation(fields: [contributorId], references: [id])
  claims      StreamClaim[]

  @@index([wallet])
  @@index([contributorId])
  @@map("stream_shares")
}

// One claim event against a stream share — the accrued amount pulled at a point
// in time. Kept for cabinet history and tx traceability.
model StreamClaim {
  id        String   @id @default(cuid())
  shareId   String
  amount    BigInt   // gross accrued claimed this time
  netAmount BigInt?
  feeAmount BigInt?
  txHash    String?  @unique
  claimedAt DateTime @default(now())

  share StreamShare @relation(fields: [shareId], references: [id])

  @@map("stream_claims")
}

model Contributor {
  id         String  @id @default(cuid())
  projectId  String
  wallet     String?
  percentage Int     // basis points; used in PERCENTAGE projects (0 in FIXED)
  fixedAmount BigInt? // USDC 6 dec per payout; used in FIXED projects
  name       String? // display name, e.g. "Maya K." (optional; role is required)
  role       String
  active     Boolean @default(true)
  totalPaid  BigInt  @default(0)

  // Invite-link flow: owner creates a slot (role+percentage) without a wallet,
  // shares inviteToken as a link, participant claims it with their own wallet.
  // claimedByPrivyId is intentionally never exposed via owner-facing API responses —
  // it exists only to prevent re-claiming an already-claimed invite.
  status           ContributorStatus @default(CLAIMED)
  inviteToken      String?           @unique
  claimedByPrivyId String?

  project      Project       @relation(fields: [projectId], references: [id])
  payouts      Payout[]
  streamShares StreamShare[]

  @@unique([projectId, wallet])
  @@map("contributors")
}

enum ContributorStatus {
  PENDING
  CLAIMED
}

model Transaction {
  id          String   @id @default(cuid())
  projectId   String
  userId      String?
  type        TxType
  amount      BigInt
  txHash      String   @unique
  blockNumber BigInt
  timestamp   DateTime
  fromAddress String?
  toAddress   String?
  role        String?
  createdAt   DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id])
  user    User?   @relation(fields: [userId], references: [id])

  @@map("transactions")
}

enum TxType {
  DEPOSIT
  PAYMENT
  DISTRIBUTION
}

// Custodial treasury balance: users top up via card (Stripe) or crypto
// (USDC transfer to the platform treasury wallet). Balance = sum of CONFIRMED
// amounts. Allocation out of the treasury into project vaults is a later phase.
model TreasuryDeposit {
  id              String          @id @default(cuid())
  userId          String
  source          TreasurySource
  amount          BigInt          // USDC, 6 decimals
  status          TreasuryStatus  @default(PENDING)
  stripeSessionId String?         @unique
  txHash          String?         @unique
  createdAt       DateTime        @default(now())
  confirmedAt     DateTime?

  user User @relation(fields: [userId], references: [id])

  @@map("treasury_deposits")
}

enum TreasurySource {
  CARD
  CRYPTO
}

enum TreasuryStatus {
  PENDING
  CONFIRMED
  FAILED
}

// Custodial distribution: owner splits an amount from the treasury across a
// project's contributors by basis points. Creates one Payout per contributor.
// No on-chain tx — neither owner nor contributor needs a wallet to distribute.
// Treasury balance = sum(CONFIRMED deposits) − sum(Distribution.total).
model Distribution {
  id        String   @id @default(cuid())
  projectId String
  total     BigInt   // USDC, 6 decimals — sum of payout amounts created
  createdAt DateTime @default(now())

  project Project  @relation(fields: [projectId], references: [id])
  payouts Payout[]

  @@map("distributions")
}

// A contributor's claimable share from a distribution. Sits in the treasury
// until the contributor claims it from their cabinet; on claim the executor
// wallet transfers (amount − fee) USDC to their wallet and pays the gas, so the
// contributor effectively covers the transfer fee out of their own share.
model Payout {
  id             String       @id @default(cuid())
  distributionId String
  projectId      String
  contributorId  String?      // owning contributor — lets us reserve a share before a wallet is linked
  wallet         String?      // payout address (lowercased); null while the invite is unclaimed
  amount         BigInt       // gross USDC owed, 6 decimals
  status         PayoutStatus @default(PENDING)
  netAmount      BigInt?      // amount actually sent (amount − fee)
  feeAmount      BigInt?      // transfer fee deducted from the share
  txHash         String?      @unique
  createdAt      DateTime     @default(now())
  claimedAt      DateTime?

  distribution Distribution @relation(fields: [distributionId], references: [id])
  project      Project      @relation(fields: [projectId], references: [id])
  contributor  Contributor? @relation(fields: [contributorId], references: [id])

  @@index([wallet, status])
  @@index([contributorId])
  @@map("payouts")
}

enum PayoutStatus {
  PENDING
  CLAIMED
}
