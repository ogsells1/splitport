generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  privyId   String   @unique
  email     String?
  wallet    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects         Project[]
  transactions     Transaction[]
  treasuryDeposits TreasuryDeposit[]

  @@map("users")
}

model Project {
  id              String   @id @default(cuid())
  name            String
  contractAddress String   @unique
  usdcAddress     String
  chainId         Int      @default(5042002)
  deployBlock     BigInt?
  ownerId         String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  owner         User           @relation(fields: [ownerId], references: [id])
  contributors  Contributor[]
  transactions  Transaction[]
  distributions Distribution[]
  payouts       Payout[]

  @@map("projects")
}

model Contributor {
  id         String  @id @default(cuid())
  projectId  String
  wallet     String?
  percentage Int
  role       String
  active     Boolean @default(true)
  totalPaid  BigInt  @default(0)

  // Invite-link flow: owner creates a slot (role+percentage) without a wallet,
  // shares inviteToken as a link, participant claims it with their own wallet.
  // claimedByPrivyId is intentionally never exposed via owner-facing API responses —
  // it exists only to prevent re-claiming an already-claimed invite.
  status           ContributorStatus @default(CLAIMED)
  inviteToken      String?           @unique
  claimedByPrivyId String?

  project Project  @relation(fields: [projectId], references: [id])
  payouts Payout[]

  @@unique([projectId, wallet])
  @@map("contributors")
}

enum ContributorStatus {
  PENDING
  CLAIMED
}

model Transaction {
  id          String   @id @default(cuid())
  projectId   String
  userId      String?
  type        TxType
  amount      BigInt
  txHash      String   @unique
  blockNumber BigInt
  timestamp   DateTime
  fromAddress String?
  toAddress   String?
  role        String?
  createdAt   DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id])
  user    User?   @relation(fields: [userId], references: [id])

  @@map("transactions")
}

enum TxType {
  DEPOSIT
  PAYMENT
  DISTRIBUTION
}

// Custodial treasury balance: users top up via card (Stripe) or crypto
// (USDC transfer to the platform treasury wallet). Balance = sum of CONFIRMED
// amounts. Allocation out of the treasury into project vaults is a later phase.
model TreasuryDeposit {
  id              String          @id @default(cuid())
  userId          String
  source          TreasurySource
  amount          BigInt          // USDC, 6 decimals
  status          TreasuryStatus  @default(PENDING)
  stripeSessionId String?         @unique
  txHash          String?         @unique
  createdAt       DateTime        @default(now())
  confirmedAt     DateTime?

  user User @relation(fields: [userId], references: [id])

  @@map("treasury_deposits")
}

enum TreasurySource {
  CARD
  CRYPTO
}

enum TreasuryStatus {
  PENDING
  CONFIRMED
  FAILED
}

// Custodial distribution: owner splits an amount from the treasury across a
// project's contributors by basis points. Creates one Payout per contributor.
// No on-chain tx — neither owner nor contributor needs a wallet to distribute.
// Treasury balance = sum(CONFIRMED deposits) − sum(Distribution.total).
model Distribution {
  id        String   @id @default(cuid())
  projectId String
  total     BigInt   // USDC, 6 decimals — sum of payout amounts created
  createdAt DateTime @default(now())

  project Project  @relation(fields: [projectId], references: [id])
  payouts Payout[]

  @@map("distributions")
}

// A contributor's claimable share from a distribution. Sits in the treasury
// until the contributor claims it from their cabinet; on claim the executor
// wallet transfers (amount − fee) USDC to their wallet and pays the gas, so the
// contributor effectively covers the transfer fee out of their own share.
model Payout {
  id             String       @id @default(cuid())
  distributionId String
  projectId      String
  contributorId  String?      // owning contributor — lets us reserve a share before a wallet is linked
  wallet         String?      // payout address (lowercased); null while the invite is unclaimed
  amount         BigInt       // gross USDC owed, 6 decimals
  status         PayoutStatus @default(PENDING)
  netAmount      BigInt?      // amount actually sent (amount − fee)
  feeAmount      BigInt?      // transfer fee deducted from the share
  txHash         String?      @unique
  createdAt      DateTime     @default(now())
  claimedAt      DateTime?

  distribution Distribution @relation(fields: [distributionId], references: [id])
  project      Project      @relation(fields: [projectId], references: [id])
  contributor  Contributor? @relation(fields: [contributorId], references: [id])

  @@index([wallet, status])
  @@index([contributorId])
  @@map("payouts")
}

enum PayoutStatus {
  PENDING
  CLAIMED
}
